    "test": "turbo run test",
    "tauri": "pnpm --filter velata-desktop tauri"
  },
  "devDependencies": {
    "@velata/config": "workspace:*",
    "eslint": "^10.6.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  }
